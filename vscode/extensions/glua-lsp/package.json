{
  "name": "glua-lsp",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.0.0",
  "publisher": "Zing",
  "author": "Zing",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZingYao/go-lua-vm.git",
    "directory": "vscode/extensions/glua-lsp"
  },
  "bugs": {
    "url": "https://github.com/ZingYao/go-lua-vm/issues"
  },
  "homepage": "https://github.com/ZingYao/go-lua-vm/tree/master/vscode/extensions/glua-lsp",
  "license": "UNLICENSED",
  "keywords": [
    "lua",
    "glua",
    "language-server",
    "debug-adapter"
  ],
  "scripts": {
    "build": "esbuild extension.js --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js && esbuild server/index.js --bundle --platform=node --format=cjs --outfile=dist/server.js",
    "vscode:prepublish": "npm run build",
    "test": "node test/golden-diagnostics.test.js && node test/golden-require-definition.test.js && node test/golden-completion.test.js && node test/formatting.test.js && node test/debug-attach.test.js"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:glua",
    "onLanguage:lua",
    "workspaceContains:**/*.glua",
    "workspaceContains:**/*.lua",
    "onCommand:glua.openBuiltinSignatureJson",
    "onCommand:glua.showBuiltinDocStatus",
    "onCommand:glua.startAttachDebug",
    "onCommand:glua.runCurrentFile",
    "onCommand:glua.debugCurrentFile",
    "onCommand:glua.selectGluaExecutable",
    "onCommand:glua.selectGluacExecutable",
    "onDebugResolve:glua"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "glua.openBuiltinSignatureJson",
        "title": "%glua.openBuiltinSignatureJson.title%"
      },
      {
        "command": "glua.showBuiltinDocStatus",
        "title": "%glua.showBuiltinDocStatus.title%"
      },
      {
        "command": "glua.showOutput",
        "title": "%glua.showOutput.title%"
      },
      {
        "command": "glua.createAttachConfig",
        "title": "%glua.createAttachConfig.title%"
      },
      {
        "command": "glua.startAttachDebug",
        "title": "%glua.startAttachDebug.title%"
      },
      {
        "command": "glua.runCurrentFile",
        "title": "%glua.runCurrentFile.title%"
      },
      {
        "command": "glua.debugCurrentFile",
        "title": "%glua.debugCurrentFile.title%"
      },
      {
        "command": "glua.selectGluaExecutable",
        "title": "%glua.selectGluaExecutable.title%"
      },
      {
        "command": "glua.selectGluacExecutable",
        "title": "%glua.selectGluacExecutable.title%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "glua.openBuiltinSignatureJson",
          "when": "true"
        },
        {
          "command": "glua.showBuiltinDocStatus",
          "when": "true"
        },
        {
          "command": "glua.showOutput",
          "when": "true"
        },
        {
          "command": "glua.createAttachConfig",
          "when": "true"
        },
        {
          "command": "glua.startAttachDebug",
          "when": "true"
        },
        {
          "command": "glua.runCurrentFile",
          "when": "true"
        },
        {
          "command": "glua.debugCurrentFile",
          "when": "true"
        },
        {
          "command": "glua.selectGluaExecutable",
          "when": "true"
        },
        {
          "command": "glua.selectGluacExecutable",
          "when": "true"
        }
      ],
      "editor/context": [
        {
          "command": "glua.runCurrentFile",
          "when": "resourceExtname == .glua || resourceExtname == .lua",
          "group": "navigation@1"
        },
        {
          "command": "glua.debugCurrentFile",
          "when": "resourceExtname == .glua || resourceExtname == .lua",
          "group": "navigation@2"
        }
      ]
    },
    "debuggers": [
      {
        "type": "glua",
        "label": "GLua",
        "languages": [
          "glua",
          "lua"
        ],
        "configurationAttributes": {
          "attach": {
            "required": [
              "request",
              "type",
              "name"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "glua"
                ],
                "description": "Debug adapter type."
              },
              "request": {
                "type": "string",
                "enum": [
                  "attach"
                ],
                "description": "Attach to an existing GLua DAP server."
              },
              "name": {
                "type": "string",
                "description": "Configuration name shown in the debug dropdown."
              }
            }
          },
          "launch": {
            "required": [
              "request",
              "type",
              "name",
              "program"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "glua"
                ],
                "description": "Debug adapter type."
              },
              "request": {
                "type": "string",
                "enum": [
                  "launch"
                ],
                "description": "Launch GLua script debugging. The extension manages the DAP connection address internally."
              },
              "name": {
                "type": "string",
                "description": "Configuration name shown in the debug dropdown."
              },
              "program": {
                "type": "string",
                "description": "Lua/glua script file to debug."
              },
              "gluaExecutable": {
                "type": "string",
                "description": "Path to glua executable. Defaults to glua.executable."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [],
                "description": "Arguments passed to glua by launch helpers."
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for glua."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "glua",
            "request": "attach",
            "name": "Attach to GLua DAP"
          },
          {
            "type": "glua",
            "request": "launch",
            "name": "Debug current GLua file",
            "program": "${file}",
            "gluaExecutable": "${config:glua.executable}",
            "args": [],
            "cwd": "${workspaceFolder}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "GLua: Attach to DAP server",
            "description": "Attach VS Code to a running GLua Debug Adapter Protocol server over TCP.",
            "body": {
              "type": "glua",
              "request": "attach",
              "name": "Attach to GLua DAP"
            }
          },
          {
            "label": "GLua: Debug current file",
            "description": "Debug the current Lua/glua file using the configured glua executable.",
            "body": {
              "type": "glua",
              "request": "launch",
              "name": "Debug current GLua file",
              "program": "${file}",
              "gluaExecutable": "${config:glua.executable}",
              "args": [],
              "cwd": "${workspaceFolder}"
            }
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "glua",
        "aliases": [
          "glua",
          "GLua"
        ],
        "extensions": [
          ".glua",
          ".lua"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "glua",
        "scopeName": "source.glua",
        "path": "./syntaxes/glua.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[glua]": {
        "editor.defaultFormatter": "local.glua-lsp",
        "editor.semanticHighlighting.enabled": true,
        "editor.semanticTokenColorCustomizations": {
          "enabled": true,
          "rules": {
            "keyword": "#CC7832",
            "function": "#56A8F5",
            "method": "#56A8F5",
            "namespace": "#4EC9B0"
          }
        },
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": "keyword.control.glua",
              "settings": {
                "foreground": "#CC7832"
              }
            },
            {
              "scope": [
                "entity.name.function.glua",
                "entity.name.function.call.glua",
                "entity.name.function.member.glua"
              ],
              "settings": {
                "foreground": "#56A8F5"
              }
            },
            {
              "scope": "entity.name.type.library.glua",
              "settings": {
                "foreground": "#4EC9B0"
              }
            }
          ]
        }
      }
    },
    "configuration": {
      "title": "glua",
      "properties": {
        "glua.syntax": {
          "type": "string",
          "default": "extended",
          "enum": [
            "extended",
            "lua53",
            "continue",
            "switch"
          ],
          "description": "Syntax mode passed to gluals: extended, lua53, continue, switch, or comma-separated extensions."
        },
        "glua.docLanguage": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-CN"
          ],
          "description": "Language tag used for builtin docs, hover text and signatures."
        },
        "glua.executable": {
          "type": "string",
          "default": "",
          "description": "Path to the glua executable used by debug launch helpers."
        },
        "glua.gluacExecutable": {
          "type": "string",
          "default": "",
          "description": "Path to the gluac executable used by compile helpers."
        },
        "glua.builtinDocs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Absolute or workspace-relative JSON files to extend or override builtin function docs."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
