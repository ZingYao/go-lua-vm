{
  "name": "glua-lsp",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.0.0",
  "publisher": "Zing",
  "author": "Zing",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZingYao/go-lua-vm.git",
    "directory": "vscode/extensions/glua-lsp"
  },
  "bugs": {
    "url": "https://github.com/ZingYao/go-lua-vm/issues"
  },
  "homepage": "https://github.com/ZingYao/go-lua-vm/tree/master/vscode/extensions/glua-lsp",
  "license": "UNLICENSED",
  "keywords": [
    "lua",
    "glua",
    "language-server",
    "debug-adapter"
  ],
  "scripts": {
    "build": "esbuild extension.js --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js && esbuild server/index.js --bundle --platform=node --format=cjs --outfile=dist/server.js",
    "vscode:prepublish": "npm run build",
    "test": "node test/golden-diagnostics.test.js && node test/golden-require-definition.test.js && node test/debug-attach.test.js"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:glua",
    "onLanguage:lua",
    "workspaceContains:**/*.glua",
    "workspaceContains:**/*.lua",
    "onCommand:glua.openBuiltinSignatureJson",
    "onCommand:glua.showBuiltinDocStatus",
    "onCommand:glua.startAttachDebug",
    "onDebugResolve:glua"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "glua.openBuiltinSignatureJson",
        "title": "%glua.openBuiltinSignatureJson.title%"
      },
      {
        "command": "glua.showBuiltinDocStatus",
        "title": "%glua.showBuiltinDocStatus.title%"
      },
      {
        "command": "glua.showOutput",
        "title": "%glua.showOutput.title%"
      },
      {
        "command": "glua.createAttachConfig",
        "title": "%glua.createAttachConfig.title%"
      },
      {
        "command": "glua.startAttachDebug",
        "title": "%glua.startAttachDebug.title%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "glua.openBuiltinSignatureJson",
          "when": "true"
        },
        {
          "command": "glua.showBuiltinDocStatus",
          "when": "true"
        },
        {
          "command": "glua.showOutput",
          "when": "true"
        },
        {
          "command": "glua.createAttachConfig",
          "when": "true"
        },
        {
          "command": "glua.startAttachDebug",
          "when": "true"
        }
      ]
    },
    "debuggers": [
      {
        "type": "glua",
        "label": "GLua",
        "languages": [
          "glua",
          "lua"
        ],
        "configurationAttributes": {
          "attach": {
            "required": [
              "request",
              "type",
              "name",
              "host",
              "port"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "glua"
                ],
                "description": "Debug adapter type."
              },
              "request": {
                "type": "string",
                "enum": [
                  "attach"
                ],
                "description": "Attach to an existing GLua DAP server."
              },
              "name": {
                "type": "string",
                "description": "Configuration name shown in the debug dropdown."
              },
              "host": {
                "type": "string",
                "default": "127.0.0.1",
                "description": "GLua DAP server IP address or host name."
              },
              "port": {
                "type": "number",
                "default": 5678,
                "minimum": 1,
                "maximum": 65535,
                "description": "GLua DAP server TCP port."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "glua",
            "request": "attach",
            "name": "Attach to GLua DAP",
            "host": "127.0.0.1",
            "port": 5678
          }
        ],
        "configurationSnippets": [
          {
            "label": "GLua: Attach to DAP server",
            "description": "Attach VS Code to a running GLua Debug Adapter Protocol server over TCP.",
            "body": {
              "type": "glua",
              "request": "attach",
              "name": "Attach to GLua DAP",
              "host": "${1:127.0.0.1}",
              "port": 5678
            }
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "glua",
        "aliases": [
          "glua",
          "GLua"
        ],
        "extensions": [
          ".glua",
          ".lua"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "glua",
        "scopeName": "source.glua",
        "path": "./syntaxes/glua.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[glua]": {
        "editor.defaultFormatter": "local.glua-lsp",
        "editor.semanticHighlighting.enabled": true,
        "editor.semanticTokenColorCustomizations": {
          "enabled": true,
          "rules": {
            "keyword": "#CC7832",
            "function": "#56A8F5",
            "method": "#56A8F5",
            "namespace": "#4EC9B0"
          }
        },
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": "keyword.control.glua",
              "settings": {
                "foreground": "#CC7832"
              }
            },
            {
              "scope": [
                "entity.name.function.glua",
                "entity.name.function.call.glua",
                "entity.name.function.member.glua"
              ],
              "settings": {
                "foreground": "#56A8F5"
              }
            },
            {
              "scope": "entity.name.type.library.glua",
              "settings": {
                "foreground": "#4EC9B0"
              }
            }
          ]
        }
      }
    },
    "configuration": {
      "title": "glua",
      "properties": {
        "glua.syntax": {
          "type": "string",
          "default": "extended",
          "description": "Syntax mode passed to gluals: extended, lua53, continue, switch, or comma-separated extensions."
        },
        "glua.docLanguage": {
          "type": "string",
          "default": "auto",
          "description": "Language tag used for builtin docs, hover text and signatures. Use auto to follow VS Code, or set tags like en, zh-CN, ja, ko, fr-FR."
        },
        "glua.builtinDocs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Absolute or workspace-relative JSON files to extend or override builtin function docs."
        },
        "glua.debug.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Default GLua DAP server IP address or host name used when creating attach configurations."
        },
        "glua.debug.port": {
          "type": "number",
          "default": 5678,
          "minimum": 1,
          "maximum": 65535,
          "description": "Default GLua DAP server TCP port used when creating attach configurations."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
