<idea-plugin>
  <id>com.glua.jetbrains</id>
  <name>GLua 语言扩展</name>
  <vendor url="https://github.com/ZingYao/go-lua-vm">zing</vendor>
  <description><![CDATA[
    <h2>GLua 语言扩展</h2>
    <p>面向 <b>go-lua-vm</b> 的 Lua/glua 编辑器支持，覆盖日常编码、模块跳转、文档提示和 DAP 调试连接。</p>
    <ul>
      <li>识别 <code>.lua</code> / <code>.glua</code> 文件，并提供语法高亮。</li>
      <li>支持 glua 扩展语法诊断、关键字补全、作用域符号补全和模块成员补全。</li>
      <li>支持 <code>require</code> 返回表成员、<code>function M:foo()</code> 冒号方法、table literal 函数字段的跳转与文档提示。</li>
      <li>支持格式化、自定义内置函数 JSON 文档、中文/英文文档语言切换。</li>
      <li>支持配置 <code>glua</code> / <code>gluac</code> 可执行文件，并在 <code>.lua</code> / <code>.glua</code> 文件中快速运行或 Debug。</li>
    </ul>
    <p>调试能力基于 JetBrains DAP，DAP 地址由扩展内部管理，用户不需要填写 host/port。</p>
  ]]></description>
  <change-notes><![CDATA[
    <ul>
      <li>版本 1.0：发布 JetBrains glua 语言支持。</li>
      <li>新增 Lua/glua 文件识别、语法高亮、扩展语法诊断、补全、文档和格式化。</li>
      <li>新增 GLua Debug 入口，由扩展内部启动 glua DAP 服务并输出启动日志。</li>
      <li>补充 require 返回表成员跳转和 table.member = function(...) 格式化支持。</li>
    </ul>
  ]]></change-notes>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
      name="GLua"
      language="GLua"
      implementationClass="com.glua.jetbrains.GluaFileType"
      fieldName="INSTANCE"
      extensions="glua;lua"/>

    <lang.syntaxHighlighterFactory
      language="GLua"
      implementationClass="com.glua.jetbrains.GluaSyntaxHighlighterFactory"/>

    <lang.parserDefinition
      language="GLua"
      implementationClass="com.glua.jetbrains.GluaParserDefinition"/>

    <lang.commenter
      language="GLua"
      implementationClass="com.glua.jetbrains.GluaCommenter"/>

    <gotoDeclarationHandler
      implementation="com.glua.jetbrains.GluaGotoDeclarationHandler"/>

    <psi.referenceContributor
      language="GLua"
      implementation="com.glua.jetbrains.GluaBuiltinReferenceContributor"/>

    <enterHandlerDelegate
      implementation="com.glua.jetbrains.GluaEnterHandler"/>

    <postFormatProcessor
      implementation="com.glua.jetbrains.GluaPostFormatProcessor"/>

    <xdebugger.breakpointType
      implementation="com.glua.jetbrains.GluaLineBreakpointType"/>

    <applicationService
      serviceImplementation="com.glua.jetbrains.GluaSettings"/>

    <applicationConfigurable
      instance="com.glua.jetbrains.GluaSettingsConfigurable"
      displayName="GLua"/>

    <platform.lsp.serverSupportProvider
      implementation="com.glua.jetbrains.GluaLspServerSupportProvider"/>

    <configurationType
      implementation="com.glua.jetbrains.GluaDapRunConfigurationType"/>

    <programRunner
      id="GluaDebugProgramRunner"
      implementation="com.glua.jetbrains.GluaDebugProgramRunner"/>

  </extensions>

  <actions resource-bundle="messages.GluaActionsBundle">
    <action
      id="Glua.FormatFile"
      class="com.glua.jetbrains.GluaFormatAction">
      <add-to-group group-id="CodeMenu" anchor="last"/>
    </action>
    <action
      id="Glua.RunCurrentFile"
      class="com.glua.jetbrains.GluaRunCurrentFileAction">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
    <action
      id="Glua.DebugCurrentFile"
      class="com.glua.jetbrains.GluaRunCurrentFileAction$Debug">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
