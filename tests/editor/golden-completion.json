{
  "files": {
    "app/completion_module.lua": "local M = {}\n-- description: print many times\n-- param: name string user name\n-- param: times number repeat count\nM.timesPrint = function(name, times) end\nfunction M.dotCall(value) end\n-- description: call with self\n-- param: value string payload\n-- return: string result\nfunction M:colonCall(value) end\nM['bracketCall'] = function() end\nreturn M\n",
    "app/literal_completion.lua": "local M = { literalCall = function() end, ['indexedLiteral'] = function() end, plainValue = true }\nreturn M\n",
    "app/const_completion.lua": "local M = {}\nM._glua_const = { a = 1, b = 2 }\nM.mutable = 3\nreturn M\n",
    "app/non_function_completion.lua": "local M = { ccc = true, value = 1 }\nreturn M\n",
    "app/private_completion.lua": "local Private = {}\nPrivate.hidden = function() end\nlocal Public = {}\nPublic.visible = function() end\nreturn Public\n"
  },
  "cases": [
    {
      "name": "numeric for variable completion",
      "kind": "file-symbol",
      "source": "local total = 0\nfor i = 1, 3 do\n  \nend\n",
      "marker": "  \nend",
      "expected": [
        "i",
        "total"
      ]
    },
    {
      "name": "generic for variables completion",
      "kind": "file-symbol",
      "source": "local values = {}\nfor a, d in pairs(values) do\n  \nend\n",
      "marker": "  \nend",
      "expected": [
        "a",
        "d",
        "values"
      ]
    },
    {
      "name": "function parameter and local completion",
      "kind": "file-symbol",
      "source": "local prefix = 'hello'\nlocal function greet(name)\n  local suffix = '!'\n  \nend\n",
      "marker": "  \nend",
      "expected": [
        "greet",
        "name",
        "prefix",
        "suffix"
      ],
      "detailContains": {
        "greet": "greet(name)"
      },
      "insertTextContains": {
        "greet": "greet(${1:name})"
      }
    },
    {
      "name": "for statement do keyword completion",
      "kind": "keyword",
      "source": "for i = 1, 100 d\n",
      "marker": "d\n",
      "expected": [
        "do"
      ],
      "notExpected": [
        "dofile",
        "glua doc comment",
        "glua documented function"
      ]
    },
    {
